  "JWT": {
    "Issuer": "ken",
    "Audience": "ken",
    // 下面的key一定要修改!!!
    // 下面的key一定要修改!!!
    // 下面的key一定要修改!!!
    // 准备一个32长度的acsii码，base64放到下面。因为Microsoft.AspNetCore.Authentication.JwtBearerConfigureOptions.GetIssuerSigningKeys里是这么实现的
